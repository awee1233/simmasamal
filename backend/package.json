{
	"name": "simmasamal-backend",
	"version": "1.0.0",
	"description": "SIMMASAMAL REST API (Express + TypeScript + Prisma)",
	"main": "dist/index.js",
	"scripts": {
		"dev": "tsx watch src/index.ts",
		"build": "tsc",
		"start": "node dist/index.js",
		"prisma:generate": "prisma generate",
		"prisma:migrate": "prisma migrate dev",
		"prisma:deploy": "prisma migrate deploy",
		"prisma:studio": "prisma studio",
		"typecheck": "tsc --noEmit",
		"test": "vitest run"
	},
	"dependencies": {
		"@prisma/client": "5.22.0",
		"axios": "1.7.9",
		"bcryptjs": "2.4.3",
		"cors": "2.8.5",
		"dotenv": "16.4.7",
		"exceljs": "4.4.0",
		"express": "4.21.2",
		"jsonwebtoken": "9.0.2",
		"midtrans-client": "1.4.2",
		"multer": "1.4.5-lts.1",
		"pdfkit": "0.15.2",
		"tsc-alias": "^1.8.17",
		"tsconfig-paths": "^4.2.0",
		"uuid": "11.0.5",
		"zod": "3.24.1"
	},
	"devDependencies": {
		"@types/bcryptjs": "2.4.6",
		"@types/cors": "2.8.17",
		"@types/express": "4.17.21",
		"@types/jsonwebtoken": "9.0.7",
		"@types/multer": "1.4.12",
		"@types/node": "22.10.5",
		"@types/pdfkit": "0.13.9",
		"@types/uuid": "10.0.0",
		"prisma": "5.22.0",
		"tsx": "4.19.2",
		"typescript": "5.7.3",
		"vitest": "2.1.8"
	}
}
